<div id="onboarding-step" class="step-fragment">
    <p class="is-uppercase has-text-weight-semibold has-text-grey is-size-7 mb-3">Step {{ currentStepNumber }} of {{ totalSteps }}</p>
    <h2 class="title is-3 mb-3">Configure {{ providerLabel }}.</h2>
    {% if requiresApiKey %}
    <p class="subtitle is-5 has-text-grey-dark">Add the API key for {{ providerLabel }} and choose the model you want to use.</p>
    {% else %}
    <p class="subtitle is-5 has-text-grey-dark">Choose the model you want to use. Ollama does not require an API key here.</p>
    {% endif %}

    {% if error %}
    <article class="message is-danger">
        <div class="message-body">{{ error }}</div>
    </article>
    {% endif %}

    <form method="post" action="/onboarding/credentials">
        {% if requiresApiKey %}
        {% if systemWideTokenName %}
        <div class="message is-link mb-4">
            <div class="message-body">
                <p class="has-text-weight-semibold mb-1">&#128273; {{ systemWideTokenName }} token detected</p>
                <p class="mb-3">We found your {{ systemWideTokenName }} token on this machine. You can reuse it directly — no separate API key needed.</p>
                <p class="mb-3"><strong>Important</strong>: this violates the terms of your {{ systemWideTokenName }} subscription and may result in account suspension.</p>
                <button class="button is-link" type="submit" name="useSystemToken" value="true">Use {{ systemWideTokenName }} token</button>
            </div>
        </div>
        <p class="has-text-grey has-text-weight-semibold mb-3 has-text-centered">— or enter an API key manually —</p>
        {% endif %}
        <div class="field">
            <label class="label" for="apiKey">API key</label>
            <div class="control">
                <input id="apiKey" class="input is-medium" type="password" name="apiKey" value="{{ apiKey }}" placeholder="Paste the API key for {{ providerLabel }}" autocomplete="off">
            </div>
        </div>
        {% endif %}

        <div class="field">
            <label class="label" for="model">Model</label>
            <div class="control">
                <input id="model" class="input is-medium" type="text" name="model" value="{{ model }}" placeholder="Enter a model name" autocomplete="off">
            </div>
        </div>

        <div class="notification is-light mt-4">
            <p class="has-text-weight-semibold mb-2">Stored properties</p>
            <p class="has-text-grey-dark">{{ chatModelPropertyKey }}</p>
            {% if requiresApiKey %}
            <p class="has-text-grey-dark">{{ providerApiPropertyKey }}</p>
            {% endif %}
        </div>

        <div class="buttons mt-4">
            <a class="button is-light is-medium" href="{{ previousStepUrl }}">Back</a>
            <button class="button is-primary is-medium" type="submit">Continue</button>
            <span class="button is-ghost is-medium htmx-indicator">Saving...</span>
        </div>
    </form>
</div>