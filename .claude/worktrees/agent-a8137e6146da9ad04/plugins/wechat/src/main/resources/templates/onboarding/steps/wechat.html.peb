<div id="onboarding-step" class="step-fragment">
    <p class="is-uppercase has-text-weight-semibold has-text-grey is-size-7 mb-3">Step {{ currentStepNumber }} of {{ totalSteps }}</p>
    <h2 class="title is-3 mb-3">Connect your WeChat Work bot.</h2>
    <p class="subtitle is-5 has-text-grey-dark">
        Scan the QR code below with your WeChat Work (Enterprise WeChat) app to authorise the iLink bot.
        Once confirmed, your bot token will be saved automatically. This step is optional.
    </p>

    {% if error %}
    <article class="message is-danger">
        <div class="message-body">{{ error }}</div>
    </article>
    {% endif %}

    {% if wechatConfigured %}
    <article class="message is-success">
        <div class="message-body">WeChat bot is already configured. You can re-scan to update the token, or continue.</div>
    </article>
    {% endif %}

    <div class="box mb-5">
        <p class="has-text-weight-semibold mb-4">Scan with WeChat Work</p>

        <div id="qrcode-area" class="has-text-centered mb-4">
            <button id="load-qr-btn" class="button is-info" type="button" onclick="loadQrCode()">Load QR Code</button>
            <div id="qrcode-container" style="display:none;">
                <img id="qrcode-img" src="" alt="WeChat QR Code" style="max-width:220px; border:1px solid #ddd; border-radius:4px;">
            </div>
            <div id="qrcode-error" class="has-text-danger mt-2" style="display:none;"></div>
        </div>

        <div id="status-area" style="display:none;" class="has-text-centered mb-4">
            <p id="status-message" class="has-text-grey-dark">Waiting for scan&hellip;</p>
            <progress id="status-spinner" class="progress is-small is-info mt-2" style="max-width:200px; margin:0 auto;"></progress>
        </div>

        <div id="confirmed-area" style="display:none;" class="has-text-centered mb-4">
            <span class="tag is-success is-medium">Connected!</span>
            <p class="has-text-grey-dark mt-2">Your WeChat bot token has been saved to the session.</p>
        </div>
    </div>

    <form method="post" action="/onboarding/wechat" id="wechat-form">
        <input type="hidden" name="wechatBotToken" id="wechatBotTokenField" value="{{ wechatBotToken }}">
        <input type="hidden" name="wechatBaseUrl" id="wechatBaseUrlField" value="">

        <div class="notification is-light mt-4">
            <p class="has-text-weight-semibold mb-2">Stored properties</p>
            <p class="has-text-grey-dark">agent.channels.wechat.bot-token</p>
            <p class="has-text-grey-dark">agent.channels.wechat.base-url</p>
        </div>

        <div class="buttons mt-4">
            <a class="button is-light is-medium" href="{{ previousStepUrl }}">Back</a>
            <button class="button is-primary is-medium" type="submit" id="continue-btn">Continue</button>
            {% if isOptional %}<a class="button is-ghost is-medium" href="{{ nextStepUrl }}">Skip</a>{% endif %}
        </div>
    </form>

    <script>
        var pollInterval = null;

        function loadQrCode() {
            document.getElementById('load-qr-btn').style.display = 'none';
            document.getElementById('qrcode-error').style.display = 'none';

            fetch('/onboarding/wechat/qrcode')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.error) {
                        showQrError(data.error);
                        return;
                    }
                    // The qrcode field is a URL or identifier — show it as an image
                    var img = document.getElementById('qrcode-img');
                    img.src = data.qrcode;
                    img.onerror = function() {
                        // If the qrcode value isn't a direct image URL, use a QR rendering service
                        img.src = 'https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=' + encodeURIComponent(data.qrcode);
                        img.onerror = null;
                    };
                    document.getElementById('qrcode-container').style.display = 'block';
                    document.getElementById('status-area').style.display = 'block';
                    startPolling();
                })
                .catch(function(err) {
                    showQrError('Network error: ' + err.message);
                });
        }

        function showQrError(msg) {
            var el = document.getElementById('qrcode-error');
            el.textContent = msg;
            el.style.display = 'block';
            document.getElementById('load-qr-btn').style.display = '';
        }

        function startPolling() {
            if (pollInterval) clearInterval(pollInterval);
            pollInterval = setInterval(pollStatus, 2000);
        }

        function stopPolling() {
            if (pollInterval) {
                clearInterval(pollInterval);
                pollInterval = null;
            }
        }

        function pollStatus() {
            fetch('/onboarding/wechat/status')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.error) {
                        stopPolling();
                        showQrError(data.error);
                        return;
                    }
                    var msgEl = document.getElementById('status-message');
                    if (data.status === 0) {
                        msgEl.textContent = 'Waiting for scan…';
                    } else if (data.status === 1) {
                        msgEl.textContent = 'Scanned! Please confirm on your phone…';
                    } else if (data.status === 2) {
                        stopPolling();
                        document.getElementById('status-area').style.display = 'none';
                        document.getElementById('confirmed-area').style.display = 'block';
                        // Store token values into hidden form fields
                        document.getElementById('wechatBotTokenField').value = data.token || '';
                        document.getElementById('wechatBaseUrlField').value = data.baseUrl || '';
                        // Auto-advance to the next step after a short delay
                        setTimeout(function() {
                            document.getElementById('wechat-form').submit();
                        }, 1500);
                    }
                })
                .catch(function() {
                    // Ignore transient network errors during polling
                });
        }
    </script>
</div>
